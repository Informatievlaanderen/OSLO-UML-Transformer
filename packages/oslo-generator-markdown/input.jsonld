      "vocDefinition": [
        {
          "@language": "en",
          "@value": "This class represents the legislation,policy or policies that lie behind the Rules that govern the service."
        },
        {
          "@language": "nl",
          "@value": "Een legaal concept dat los staat van een bepaalde vorm (het achterliggende idee)."
        }
      ],
      "apUsageNote": [
        {
          "@language": "en",
          "@value": "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (<a href=\"https://eur-lex.europa.eu/eli-register/about.html\">ELI</a>)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the (<a href=\"https://op.europa.eu/en/web/eu-vocabularies/eli\">ELI</a>) ontology.\r\n\r\nIn this data specification the use is restricted to instances of this class that follow the (<a href=\"https://op.europa.eu/en/web/eu-vocabularies/eli\">ELI</a>) URI guidelines."
        },
        {
          "@language": "nl",
          "@value": "De waarden die hier gebruikt worden zijn the PURIs van de wetgeving volgens de ELI URI richtlijnen."
        }
      ],
