    {
      "@id": "urn:oslo-toolchain:a71f59399279472446f6130457d8ac76ebbfdfa2298512a446fffe78937015cd",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "assignedURI": "http://purl.org/dc/terms/accessRights",
      "apLabel": [
        {
          "@language": "nl",
          "@value": "toegankelijkheid"
        }
      ],
      "diagramLabel": [
        {
          "@value": "toegankelijkheid"
        }
      ],
      "apDefinition": [
        {
          "@language": "nl",
          "@value": "De toegankelijkheid voor de dataservice."
        }
      ],
      "apUsageNote": [
        {
          "@language": "nl",
          "@value": "Gebruik enkel de waarden PUBLIC en NON_PUBLIC uit de codelijst, waarbij PUBLIC staat voor het gebruiken van de dataservice is zonder voorwaarden, terwijl NON_PUBLIC betekent dat het gebruiken van de service gebonden is aan voorwaarden. \n \nDe condities die enkel als doel hebben om de correcte werking van de dataservice te ondersteunen (vermijden van DDOS aanvallen, vermijden van oneigenlijk gebruik, ...) zoals het toepassen van authenticatie en authorisatie worden beschouwd als zonder voorwaarden. Indien echter dit leidt tot een een toetsing (bv. is de organisatie gekend, is er een betalingscontract afgesloten, ...) voorafgaand aan de verlening van de toegang dan zijn dit wel toegangsbeperkende voorwaarden."
        }
      ],
      "extensions": [
        {
          "@type": "oslo:extension",
          "oslo:key": {
            "@language": "nl",
            "@value": "DCATAP"
          },
          "oslo:value": {
            "@language": "nl",
            "@value": "https://semiceu.github.io/DCAT-AP/releases/3.0.1/#DataService.accessrights"
          }
        },
